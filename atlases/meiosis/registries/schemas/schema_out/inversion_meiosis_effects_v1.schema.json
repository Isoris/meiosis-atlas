{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "inversion_meiosis_effects_v1.schema.json",
  "title": "inversion_meiosis_effects_v1 — HEADLINE interchromosomal chain result",
  "description": "Typed result of the `interchromosomal_inversion_effect` chain. One row per (focal_inversion × tested_chrom). The focal-chrom row is included (so the user can see intrachromosomal effect strength as a cross-check) but excluded from the BH/Bonferroni alpha control — `p_bh` and `p_bonf` are null on that row. Backs meiosis_atlas chain product inversion_meiosis_effects.",
  "type": "object",
  "required": ["rows", "summary"],
  "additionalProperties": true,
  "properties": {
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "focal_inversion_id", "tested_chrom", "is_focal_chrom",
          "n_het", "n_nonhet", "mean_diff", "t_stat",
          "p_value", "p_bh", "p_bonf", "sig_flag",
          "local_inv_burden"
        ],
        "additionalProperties": true,
        "properties": {
          "focal_inversion_id": { "type": "string", "minLength": 1 },
          "tested_chrom":       { "type": "string", "minLength": 1 },
          "is_focal_chrom":     { "type": "boolean", "description": "true iff tested_chrom is the focal inversion's own chromosome (excluded from BH alpha control)." },
          "n_het":              { "type": "integer", "minimum": 0 },
          "n_nonhet":           { "type": "integer", "minimum": 0 },
          "mean_diff":          { "type": ["number", "null"], "description": "mean(rate_het) - mean(rate_non_het). null when either group is empty." },
          "t_stat":             { "type": ["number", "null"], "description": "Welch's t (point estimate); null when degenerate (< 2 in either group)." },
          "p_value":            { "type": ["number", "null"], "minimum": 0, "maximum": 1, "description": "Two-sided permutation p (add-one smoothed)." },
          "p_bh":               { "type": ["number", "null"], "minimum": 0, "maximum": 1, "description": "Benjamini-Hochberg adjusted p; null on the focal-chrom row." },
          "p_bonf":              { "type": ["number", "null"], "minimum": 0, "maximum": 1, "description": "Bonferroni adjusted p; null on the focal-chrom row." },
          "sig_flag":           { "type": "boolean", "description": "true iff p_bh < p_bh_alpha (default 0.05). Always false on the focal-chrom row." },
          "local_inv_burden":   {
            "type": "object",
            "required": ["n_local_invs", "total_local_length_bp"],
            "additionalProperties": true,
            "properties": {
              "n_local_invs":          { "type": "integer", "minimum": 0 },
              "total_local_length_bp": { "type": "number",  "minimum": 0 }
            },
            "description": "Per-tested-chrom covariate burden from local_inv_controls.v1 — surfaced as a row-level caveat (not used in regression for v1)."
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["n_tests", "n_sig_bh", "focal_inversion_id", "class_scope", "n_permutations", "p_bh_alpha"],
      "additionalProperties": true,
      "properties": {
        "n_tests":             { "type": "integer", "minimum": 0, "description": "Off-focal-chrom tests counted toward BH/Bonferroni alpha control." },
        "n_sig_bh":            { "type": "integer", "minimum": 0 },
        "focal_inversion_id":  { "type": ["string", "null"] },
        "focal_chrom":         { "type": ["string", "null"] },
        "class_scope":         {
          "type": "object",
          "required": ["co", "dco"],
          "properties": { "co": { "type": "boolean" }, "dco": { "type": "boolean" } }
        },
        "n_permutations":      { "type": "integer", "minimum": 0 },
        "p_bh_alpha":          { "type": "number",  "minimum": 0, "maximum": 1 }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "events_layer_id":   { "type": "string" },
        "controls_layer_id": { "type": ["string", "null"] },
        "design_layer_id":   { "type": "string" },
        "module":            { "type": "string" },
        "module_version":    { "type": "string" },
        "params":            { "type": "object", "additionalProperties": true }
      }
    }
  }
}
